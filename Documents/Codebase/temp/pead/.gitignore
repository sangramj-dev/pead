# Maven build output
target/
*.jar
*.war
*.ear
*.class

# Maven wrapper JAR (keep .mvn/wrapper/maven-wrapper.properties)
.mvn/wrapper/maven-wrapper.jar

# Log files (generated at runtime — root-level and per-module)
*.log
*-err.log
*-debug.log
*-debug-err.log

# IDE — IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# IDE — VS Code
.vscode/

# IDE — Eclipse / STS
.classpath
.project
.settings/
bin/

# IDE — NetBeans
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Secrets / local config overrides (keep application.yml in source)
application-local.yml
application-local.properties
application-secret.yml
application-secret.properties
.env
.env.*

# Infrastructure runtime data (generated by docker-compose volumes)
infrastructure/postgres/data/
infrastructure/grafana/data/
infrastructure/prometheus/data/

# Temp / backup files
*.tmp
*.bak
*.swp
*.orig
